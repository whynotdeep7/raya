<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/header') %>
</head>
<body class="bg-ivory font-sans text-text-main antialiased min-h-screen flex flex-col">

<main class="flex-1 flex items-center justify-center p-4 py-24">
    <div class="w-full max-w-md bg-white rounded-2xl p-10 shadow-soft border border-warm-border/30">
        <div class="text-center mb-10">
            <div class="w-14 h-14 border border-gold/30 text-gold rounded-full flex items-center justify-center mx-auto mb-6">
                <span class="material-symbols-outlined text-2xl">favorite</span>
            </div>
            <h2 class="text-3xl font-serif font-bold text-charcoal mb-2 tracking-tight">Welcome Back</h2>
            <p class="text-text-muted text-sm font-light">Enter your details to continue your journey</p>
        </div>

        <!-- Ornamental Divider -->
        <div class="flex items-center justify-center gap-3 mb-8">
            <div class="h-px w-10 bg-warm-border"></div>
            <span class="material-symbols-outlined text-gold/40 text-[12px]">diamond</span>
            <div class="h-px w-10 bg-warm-border"></div>
        </div>

        <form class="space-y-6" action="/login" method="POST">
            <% if (error) { %>
                <div class="bg-red-50/60 text-red-600 p-4 rounded-xl text-xs font-medium border border-red-100/60">
                    <%= error %>
                </div>
            <% } %>
            <div>
                <label class="block text-[11px] font-sans font-medium text-text-muted uppercase tracking-[0.15em] mb-2">Email Address</label>
                <input type="email" name="email" required placeholder="name@example.com" class="w-full px-0 py-3 bg-transparent border-0 border-b border-warm-border focus:ring-0 focus:border-gold text-charcoal transition-colors duration-300 outline-none placeholder:text-text-muted/40 text-sm">
            </div>
            <div>
                <div class="flex justify-between mb-2">
                    <label class="block text-[11px] font-sans font-medium text-text-muted uppercase tracking-[0.15em]">Password</label>
                    <a href="#" class="text-[11px] font-sans font-medium text-gold tracking-wide hover:text-gold-light transition-colors duration-300">Forgot?</a>
                </div>
                <input type="password" name="password" required placeholder="••••••••" class="w-full px-0 py-3 bg-transparent border-0 border-b border-warm-border focus:ring-0 focus:border-gold text-charcoal transition-colors duration-300 outline-none placeholder:text-text-muted/40 text-sm">
            </div>
            
            <div class="flex items-center gap-3 pt-2">
                <input type="checkbox" class="rounded border-warm-border text-gold focus:ring-gold/30">
                <span class="text-sm text-text-muted font-light">Keep me logged in</span>
            </div>

            <button type="submit" class="w-full bg-gold text-white py-3.5 rounded-full font-sans font-medium text-sm tracking-wide shadow-gold hover:bg-gold-light transition-all duration-300 mt-2">
                Sign In
            </button>
        </form>

        <div class="mt-10 pt-8 border-t border-warm-border/50 text-center">
            <p class="text-sm text-text-muted font-light">Don't have an account? <a href="/signup" class="text-gold font-medium hover:text-gold-light transition-colors duration-300">Create one free</a></p>
        </div>
    </div>
</main>

<%- include('partials/footer') %>

</body>
</html>