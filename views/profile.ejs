<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/header') %>
</head>
<body class="bg-ivory font-sans text-text-main antialiased min-h-screen flex flex-col">

<main class="flex-1 flex items-center justify-center p-4 py-24">
    <div class="w-full max-w-2xl bg-white rounded-2xl p-10 shadow-soft border border-warm-border/30">
        <div class="text-center mb-10">
            <div class="w-20 h-20 border border-gold/30 text-gold rounded-full flex items-center justify-center mx-auto mb-6 bg-blush/40">
                <span class="material-symbols-outlined text-4xl">person</span>
            </div>
            <h2 id="profile-fullname" class="text-3xl font-serif font-bold text-charcoal mb-2 tracking-tight"></h2>
            <p id="profile-email" class="text-text-muted text-sm font-light"></p>
        </div>

        <!-- Ornamental Divider -->
        <div class="flex items-center justify-center gap-3 mb-8">
            <div class="h-px w-10 bg-warm-border"></div>
            <span class="material-symbols-outlined text-gold/40 text-[12px]">diamond</span>
            <div class="h-px w-10 bg-warm-border"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="bg-blush/30 rounded-xl p-5 border border-warm-border/30">
                <p class="text-[11px] font-sans font-medium text-text-muted uppercase tracking-[0.15em] mb-2">Age</p>
                <p id="profile-age" class="text-charcoal font-medium">Not specified</p>
            </div>
            <div class="bg-blush/30 rounded-xl p-5 border border-warm-border/30">
                <p class="text-[11px] font-sans font-medium text-text-muted uppercase tracking-[0.15em] mb-2">Gender</p>
                <p id="profile-gender" class="text-charcoal font-medium">Not specified</p>
            </div>
            <div class="bg-blush/30 rounded-xl p-5 border border-warm-border/30">
                <p class="text-[11px] font-sans font-medium text-text-muted uppercase tracking-[0.15em] mb-2">Location</p>
                <p id="profile-location" class="text-charcoal font-medium">Not specified</p>
            </div>
            <div class="bg-blush/30 rounded-xl p-5 border border-warm-border/30">
                <p class="text-[11px] font-sans font-medium text-text-muted uppercase tracking-[0.15em] mb-2">Email</p>
                <p id="profile-email-card" class="text-charcoal font-medium">Not specified</p>
            </div>
        </div>

        <div id="profile-bio-section" class="mt-6 bg-blush/30 rounded-xl p-5 border border-warm-border/30 hidden">
            <p class="text-[11px] font-sans font-medium text-text-muted uppercase tracking-[0.15em] mb-2">About Me</p>
            <p id="profile-bio" class="text-charcoal/70 leading-relaxed font-light"></p>
        </div>

        <div class="mt-8 text-center">
            <a href="/" class="inline-block bg-gold text-white px-8 py-3 rounded-full font-sans font-medium text-sm tracking-wide shadow-gold hover:bg-gold-light transition-all duration-300">
                Back to Home
            </a>
        </div>
    </div>
</main>

<script>
    (function() {
        if (localStorage.getItem('loggedIn') !== 'true') {
            window.location.href = '/login';
            return;
        }
        var email = localStorage.getItem('userEmail');
        if (!email) { window.location.href = '/login'; return; }

        fetch('/api/user?email=' + encodeURIComponent(email))
            .then(function(r) { return r.json(); })
            .then(function(user) {
                if (user.error) { window.location.href = '/login'; return; }
                document.getElementById('profile-fullname').textContent = (user.firstName || '') + ' ' + (user.lastName || '');
                document.getElementById('profile-email').textContent = user.email || '';
                document.getElementById('profile-email-card').textContent = user.email || 'Not specified';
                document.getElementById('profile-age').textContent = user.age || 'Not specified';
                document.getElementById('profile-gender').textContent = user.gender || 'Not specified';
                document.getElementById('profile-location').textContent = user.location || 'Not specified';
                if (user.bio) {
                    document.getElementById('profile-bio-section').classList.remove('hidden');
                    document.getElementById('profile-bio').textContent = user.bio;
                }
            });
    })();
</script>

<%- include('partials/footer') %>

</body>
</html>
