<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/header') %>
</head>
<body class="bg-ivory font-sans text-text-main antialiased min-h-screen flex flex-col">

<main class="flex-1 w-full max-w-[1400px] mx-auto p-4 md:p-6 lg:p-10 gap-6">
    <!-- Breadcrumbs -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <nav class="flex flex-wrap gap-2 items-center text-sm font-sans font-light">
            <a class="text-text-muted hover:text-gold transition-colors duration-300" href="/">Home</a>
            <span class="text-warm-border">·</span>
            <a class="text-text-muted hover:text-gold transition-colors duration-300" href="/discover">Matches</a>
            <span class="text-warm-border">·</span>
            <span class="text-charcoal font-medium">Aisha Kapoor</span>
        </nav>
        <div class="flex gap-3">
            <button class="flex items-center gap-2 px-5 py-2.5 rounded-full border border-warm-border text-charcoal text-[13px] font-sans font-medium hover:border-gold hover:text-gold transition-all duration-300">
                <span class="material-symbols-outlined text-[16px]">favorite</span>
                Shortlist
            </button>
            <button class="flex items-center gap-2 px-5 py-2.5 rounded-full bg-gold text-white text-[13px] font-sans font-medium shadow-gold hover:bg-gold-light transition-all duration-300">
                <span class="material-symbols-outlined text-[16px]">send</span>
                Send Interest
            </button>
        </div>
    </div>

    <!-- Profile Content -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        <!-- Gallery -->
        <div class="lg:col-span-5 flex flex-col gap-4">
            <div class="relative w-full aspect-[3/4] rounded-2xl overflow-hidden shadow-soft group">
                <img alt="Aisha Kapoor" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="https://picsum.photos/seed/aisha/800/1066"/>
                <div class="absolute bottom-4 left-4 z-20 flex flex-col">
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center justify-center size-2 bg-emerald-500 rounded-full shadow-[0_0_6px_rgba(34,197,94,0.4)]"></span>
                        <span class="text-white text-sm font-sans font-light drop-shadow-md">Online Now</span>
                    </div>
                </div>
            </div>
            <div class="grid grid-cols-4 gap-3 h-24">
                <button class="relative rounded-xl overflow-hidden ring-2 ring-gold ring-offset-2 ring-offset-ivory">
                    <img src="https://picsum.photos/seed/aisha1/200/200" class="w-full h-full object-cover" alt="Thumb">
                </button>
                <button class="relative rounded-xl overflow-hidden opacity-60 hover:opacity-100 transition-opacity duration-300">
                    <img src="https://picsum.photos/seed/aisha2/200/200" class="w-full h-full object-cover" alt="Thumb">
                </button>
                <button class="relative rounded-xl overflow-hidden opacity-60 hover:opacity-100 transition-opacity duration-300">
                    <img src="https://picsum.photos/seed/aisha3/200/200" class="w-full h-full object-cover" alt="Thumb">
                </button>
                <button class="relative rounded-xl overflow-hidden opacity-60 hover:opacity-100 transition-opacity duration-300 bg-blush flex items-center justify-center group">
                    <span class="text-text-muted text-xs font-sans font-medium group-hover:text-gold transition-colors duration-300">+3 More</span>
                </button>
            </div>
        </div>

        <!-- Info -->
        <div class="lg:col-span-7 flex flex-col gap-6">
            <div class="bg-white rounded-2xl p-8 shadow-soft border border-warm-border/30 relative overflow-hidden">
                <div class="flex-1">
                    <div class="flex items-start justify-between">
                        <div>
                            <h1 class="text-3xl font-serif font-bold text-charcoal tracking-tight">Aisha Kapoor <span class="align-middle material-symbols-outlined text-gold text-[22px]">verified</span></h1>
                            <p class="text-text-muted mt-1.5 text-lg font-light">27 · UX Designer · Mumbai, India</p>
                        </div>
                        <div class="hidden md:flex flex-col items-center justify-center p-4 rounded-xl border border-gold/20 bg-blush/40 min-w-[90px]">
                            <span class="text-2xl font-serif font-bold text-gold">94%</span>
                            <span class="text-[10px] font-sans font-medium text-text-muted uppercase tracking-[0.1em]">Match</span>
                        </div>
                    </div>
                    <div class="flex flex-wrap gap-2 mt-5">
                        <span class="px-3 py-1.5 rounded-full border border-warm-border/60 text-charcoal/70 text-sm font-sans font-light">5'6" (168 cm)</span>
                        <span class="px-3 py-1.5 rounded-full border border-warm-border/60 text-charcoal/70 text-sm font-sans font-light">Never Married</span>
                        <span class="px-3 py-1.5 rounded-full border border-warm-border/60 text-charcoal/70 text-sm font-sans font-light">Hindi / English</span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl p-8 shadow-soft border border-warm-border/30">
                <h3 class="text-xl font-serif font-bold text-charcoal mb-5">About Aisha</h3>
                <!-- Ornamental Divider -->
                <div class="flex items-center gap-3 mb-6">
                    <div class="h-px flex-1 bg-warm-border/50"></div>
                    <span class="material-symbols-outlined text-gold/30 text-[10px]">diamond</span>
                    <div class="h-px flex-1 bg-warm-border/50"></div>
                </div>
                <p class="text-charcoal/65 leading-[1.8] mb-8 font-light">
                    I'm a creative soul who loves blending technology with art. As a UX Designer, I spend my days solving problems and making things look good. On weekends, you'll find me exploring new cafes in Bandra, attempting pottery, or lost in a good sci-fi novel.
                </p>
                <div class="grid grid-cols-2 gap-8">
                    <div>
                        <h4 class="text-[11px] font-sans font-medium text-text-muted uppercase tracking-[0.15em] mb-5">Lifestyle</h4>
                        <ul class="space-y-4">
                            <li class="flex items-center gap-3 text-sm font-light text-charcoal/70"><span class="material-symbols-outlined text-gold text-lg">restaurant</span> Vegetarian</li>
                            <li class="flex items-center gap-3 text-sm font-light text-charcoal/70"><span class="material-symbols-outlined text-gold text-lg">local_bar</span> Occasionally drinks</li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-[11px] font-sans font-medium text-text-muted uppercase tracking-[0.15em] mb-5">Background</h4>
                        <ul class="space-y-4">
                            <li class="flex items-center gap-3 text-sm font-light text-charcoal/70"><span class="material-symbols-outlined text-gold text-lg">temple_hindu</span> Upper Middle Class</li>
                            <li class="flex items-center gap-3 text-sm font-light text-charcoal/70"><span class="material-symbols-outlined text-gold text-lg">family_restroom</span> Nuclear Family</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>

</body>
</html>
